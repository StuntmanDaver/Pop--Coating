# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*.local
.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# sentry
.sentryclirc

# Sentry Config File
.env.sentry-build-plugin

# Playwright MCP cache
.playwright-mcp/

# Plugin-managed skills cache (skills-lock.json is the manifest)
.claude/skills/
.agents/

# ECC rule set is mirrored from ~/.claude/rules/ via the install script;
# tracking the project-local copy creates drift.
.claude/rules/

# Ralph harness runtime state (per-loop directory)
scripts/ralph-*/ralph.pid
scripts/ralph-*/ralph.log
scripts/ralph-*/.last-branch

# Stale Firecrawl scrape attempts at .firecrawl/ root —
# the canonical scrape lives at .firecrawl/popsindustrial/
/.firecrawl/*
!/.firecrawl/popsindustrial/
