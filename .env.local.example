# Safe template only. Do not put real secret values in this file.
# Canonical env descriptions live in docs/runbooks/phase-1-production-readiness.md.

NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# Redirect targets used by src/proxy.ts (audience-domain enforcement).
# Local defaults; Vercel sets production hosts (https://app.popsindustrial.com / https://track.popsindustrial.com).
NEXT_PUBLIC_APP_HOST=http://app.localhost:3000
NEXT_PUBLIC_PORTAL_HOST=http://track.localhost:3000

# Optional local/CI smoke-test overrides.
E2E_BASE_URL=
E2E_PORTAL_BASE_URL=
E2E_STAFF_EMAIL=
E2E_STAFF_PASSWORD=
E2E_WORKSTATION_EMAIL=
E2E_WORKSTATION_PASSWORD=
E2E_CUSTOMER_EMAIL=
E2E_RUN_MAGIC_LINK_POST=
